# Server environment variables
# Copy this file to server/.env and fill in your own values.

PORT=4000
MONGODB_URL=mongodb://localhost:27017/ezybuyy
JWT_SECRET=your_jwt_secret_here

# Cloudinary credentials
CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret

# Razorpay credentials
RAZORPAY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret

# Gemini / AI key
GEMINI_API_KEY=your_gemini_api_key

# Email / contact settings
MAIL_HOST=smtp.example.com
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_email_password
COMPANY_NAME=EzyBuyy

# Cloudinary folder name for uploads
FOLDER_NAME=ezybuyy

# Agent / rate limiting defaults
AGENT_RATE_LIMIT_REQUESTS_PER_MIN=10
AGENT_RATE_LIMIT_REQUESTS_PER_DAY=100
AGENT_MAX_TOKENS_PER_REQUEST=1000
AGENT_MAX_CONVERSATION_LENGTH=20

# Negotiation settings
NEGOTIATION_MAX_DISCOUNT=15
NEGOTIATION_MIN_PRICE=99
NEGOTIATION_TTL=1800000
NEGOTIATION_MAX_ROUNDS=5
NEGOTIATION_COUNTER_FACTOR=0.6
NEGOTIATION_AUTO_ACCEPT=5
